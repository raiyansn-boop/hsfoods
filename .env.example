# HSFOODS environment configuration
PORT=4000

# WhatsApp Cloud API (Meta) — only needed for real WhatsApp integration.
# The built-in simulator works without any of these.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=hsfoods-verify

# AI assistant (Claude). Optional — without it the assistant returns a
# deterministic liability snapshot instead of natural-language answers.
ANTHROPIC_API_KEY=

# Referral program tuning (optional; defaults shown)
REFERRAL_DEFAULT_PCT=5
REFERRAL_RETURN_WINDOW_DAYS=7
REFERRAL_MARGIN_GUARD=0.5
# Loyalty cashback % every customer earns on their own orders
LOYALTY_RATE_PCT=2
